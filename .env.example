# Runtime
SYSTEM_ENV=development
LOG_LEVEL=INFO

# Provider
MODEL_PROVIDER=ollama
DEFAULT_MODEL=qwen3:32b
AGENT_MAX_STEPS=8
PROVIDER_TIMEOUT_SECONDS=120

# Ollama Cloud
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_CHAT_PATH=/chat
OLLAMA_API_KEY=REPLACE_WITH_YOUR_OLLAMA_CLOUD_API_KEY
OLLAMA_MODEL=qwen3:32b

# Safety: auto | ask | block
MCP_APPROVAL_MODE=ask

# Workspace root the assistant can operate in
WORKSPACE_ROOT=/home/mayur/Desktop/ai/system_builder

# MCP
MCP_ENABLED=true
MCP_CONFIG_PATH=./config/mcp_servers.json
